# --- Workspace (RunPod / sunucu: kalıcı disk) ---
# Tek kök dizin: proje + storage + venv aynı yerde
WORKSPACE_ROOT=/workspace
STORAGE_BASE_PATH=/workspace/storage
# Alternatif: Pod volume → /runpod/storage ; Serverless → /runpod-volume/storage

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Ngrok (canlı URL; boş bırakırsan ngrok başlamaz) ---
NGROK_AUTHTOKEN=34VmDUYcsU4QCB0cO3uwAIorNkv_2CJQkJVKtBbB5yxjroWB9

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# --- Local storage (API + worker aynı path kullanmalı) ---
INPUTS_PREFIX=inputs
OUTPUTS_PREFIX=outputs
